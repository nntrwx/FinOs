// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int    @id @default(autoincrement())
  email         String @unique
  passwordHash String
  name          String

  balance Decimal @default(0)
  monthSalary Decimal @default(0)

  transactions    Transaction[]
  monthlySummarys monthlySummary[] 
  yearlySummarys  yearlySummary[]
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionCategory {
  FOOD
  TRANSPORT
  ENTERTAINMENT
  UTILITIES
  HEALTHCARE
  OTHER
}

model Transaction {
  id Int @id @default(autoincrement())
  amount Decimal
  type TransactionType
  category TransactionCategory
  description String?
  date DateTime @default(now())
  userId Int
  monthlySummaryId Int?

  user User @relation(fields: [userId], references: [id])
  monthlySummary   monthlySummary? @relation(fields: [monthlySummaryId], references: [id])
  @@index([userId, date])
}

model monthlySummary {
  id Int @id @default(autoincrement())
  month String
  year Int
  salary Decimal @default(0)
  totalIncome Decimal @default(0)
  totalExpense Decimal @default(0)
  userId Int
  yearlySummaryId Int?

  transactions Transaction[]
  yearlySummary yearlySummary? @relation(fields: [yearlySummaryId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model yearlySummary {
  id Int @id @default(autoincrement())
  year Int
  totalIncome Decimal @default(0)
  totalExpense Decimal @default(0)
  userId Int

  monthlySummarys monthlySummary[]
  user User @relation(fields: [userId], references: [id])
}